# Build-time env for production deploy (Vite bakes these into the bundle).
# Copy to .env and set before: npm run build
#
# Required for AI (interpret + chat) on live site:
# VITE_API_URL=https://your-backend-url.com
#
# Example: If backend is on Render/Railway/Fly at https://current-api.onrender.com
# VITE_API_URL=https://current-api.onrender.com
