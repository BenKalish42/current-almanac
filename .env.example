# Build-time env for production deploy (Vite bakes these into the bundle).
# Copy to .env and set before: npm run build
#
# --- Core runtime API ---
# Required for AI (interpret + chat) on live site:
# VITE_API_URL=https://your-backend-url.com
#
# --- Supabase Auth (frontend) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
# Optional redirect target for magic-link email sign-in:
# VITE_SUPABASE_AUTH_REDIRECT_TO=https://your-web-app.example.com
#
# --- Supabase / RevenueCat / webhook server env (backend) ---
# Set these in backend/.env or your backend host environment:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key
# SUPABASE_ANON_KEY=your_publishable_key
# REVENUECAT_SECRET_API_KEY=your_revenuecat_secret_key
# REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer your_webhook_secret
# SUPABASE_AUTH_REDIRECT_URL=https://your-web-app.example.com
#
# --- RevenueCat + Stripe Web Billing (frontend) ---
# Native mobile apps use the public RevenueCat SDK key.
# Web / desktop should use the Web Billing public SDK key.
# VITE_REVENUECAT_PUBLIC_API_KEY=appl_xxx_or_goog_xxx
# VITE_REVENUECAT_WEB_API_KEY=rcb_xxx
#
# Required for Phase 3 Synthesis Engine + Task 12.2 Oracle (Generate Reading, Past/Present summaries, Current Flow):
# Option A — DeepSeek (default):
#   VITE_DEEPSEEK_API_KEY=your_deepseek_key_here  # or VITE_LLM_API_KEY
#   (VITE_LLM_API_URL defaults to https://api.deepseek.com/v1/chat/completions)
#   VITE_LLM_MODEL=deepseek-chat  # optional
# Option B — OpenAI/ChatGPT (often faster):
#   VITE_LLM_API_KEY=your_openai_key_here
#   VITE_LLM_API_URL=https://api.openai.com/v1/chat/completions
#   VITE_LLM_MODEL=gpt-4o-mini
#
# Example: If backend is on Render/Railway/Fly at https://current-api.onrender.com
# VITE_API_URL=https://current-api.onrender.com
#
# --- Capgo OTA (used in CI/CD, not baked into the client) ---
# CAPGO_TOKEN=your_capgo_api_key
# Optional encrypted bundle upload:
# CAPGO_PRIVATE_KEY=your_capgo_private_key
#
# --- App store CI/CD secrets (GitHub Actions / Fastlane) ---
# Android:
# PLAY_CONFIG_JSON=base64_service_account_json
# ANDROID_KEYSTORE_FILE=base64_keystore_file
# KEYSTORE_KEY_ALIAS=your_alias
# KEYSTORE_KEY_PASSWORD=your_key_password
# KEYSTORE_STORE_PASSWORD=your_keystore_password
# DEVELOPER_PACKAGE_NAME=com.current.almanac
#
# iOS:
# APP_STORE_CONNECT_TEAM_ID=your_team_id
# APPLE_KEY_ID=your_key_id
# APPLE_ISSUER_ID=your_issuer_id
# APPLE_KEY_CONTENT=base64_p8_contents
# BUILD_CERTIFICATE_BASE64=base64_p12
# BUILD_PROVISION_PROFILE_BASE64=base64_mobileprovision
# P12_PASSWORD=certificate_password
# APPLE_PROFILE_NAME=profile_name
# BUNDLE_IDENTIFIER=com.current.almanac
#
# --- Desktop signing / release secrets ---
# TAURI_SIGNING_PRIVATE_KEY=your_tauri_updater_private_key
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=your_private_key_password
#
# Community — Discourse (forum root URL, no trailing slash). Browser CORS must allow this app’s origin.
# VITE_DISCOURSE_BASE_URL=https://talk.example.com
# Optional global or user API key + username (exposed in client bundle if set)
# VITE_DISCOURSE_API_KEY=
# VITE_DISCOURSE_API_USERNAME=
