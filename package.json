{
  "name": "current-almanac",
  "productName": "Current Almanac",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "vitest",
    "test:llm": "node scripts/test_llm.mjs",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:embedded": "vue-tsc -b && vite build --base ./",
    "build:mobile": "npm run build:embedded && npx cap sync",
    "build:android": "npm run build:mobile && cd android && ./gradlew bundleRelease",
    "desktop:dev": "npm run build:embedded && electron .",
    "desktop:package": "npm run build:embedded && electron-forge package",
    "desktop:make": "npm run build:embedded && electron-forge make",
    "desktop:publish": "npm run build:embedded && electron-forge publish",
    "preview": "vite preview",
    "backend": "python3.12 -m uvicorn backend.main:app --reload --port 8000",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android"
  },
  "dependencies": {
    "@ai-sdk/vue": "^3.0.97",
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/geolocation": "^7.1.8",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@vueuse/core": "^14.2.1",
    "astronomia": "^4.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "iztro": "^2.5.7",
    "lottie-web": "^5.13.0",
    "lunar-javascript": "^1.7.7",
    "lunar-typescript": "^1.8.6",
    "pinia": "^3.0.4",
    "pinyin-pro": "^3.27.0",
    "pinyin-zhuyin": "^1.0.3",
    "to-jyutping": "^3.1.1",
    "update-electron-app": "^3.1.2",
    "vue": "^3.5.24",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.24",
    "electron": "^41.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.4"
  }
}
