# Supabase (required for init_db.py and safety middleware)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# DeepSeek API (Phase 4: LLM integration)
DEEPSEEK_API_KEY=your-deepseek-api-key
# Optional: DEEPSEEK_BASE_URL=https://api.deepseek.com

# Intelligence model providers (LiteLLM-routed; keys stay server-side)
# Anthropic Claude (Sonnet, Opus, Haiku)
ANTHROPIC_API_KEY=
# OpenAI ChatGPT (gpt-4o, gpt-4o-mini, o-series reasoning)
OPENAI_API_KEY=
# Google Gemini (Pro, Flash) — either GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Neo4j KnowledgeRAG (optional — falls back to seed herb/formula data)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
