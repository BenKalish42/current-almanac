default_platform(:ios)

def require_env!(key)
  value = ENV[key]
  UI.user_error!("Missing required environment variable: #{key}") if value.to_s.empty?
  value
end

def app_store_connect_key
  app_store_connect_api_key(
    key_id: require_env!("APP_STORE_CONNECT_KEY_ID"),
    issuer_id: require_env!("APP_STORE_CONNECT_ISSUER_ID"),
    key_content: require_env!("APP_STORE_CONNECT_KEY_CONTENT"),
    is_key_content_base64: ENV["APP_STORE_CONNECT_KEY_IS_BASE64"] == "true"
  )
end

def decoded_secret_file(env_key, destination)
  encoded_value = require_env!(env_key)
  FileUtils.mkdir_p(File.dirname(destination))
  File.binwrite(destination, Base64.decode64(encoded_value))
  destination
end

platform :ios do
  desc "Build and upload Current Almanac to TestFlight"
  lane :testflight do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_key
    certificate_path = decoded_secret_file("IOS_DISTRIBUTION_CERTIFICATE_BASE64", "ios/App/build/certificates/distribution.p12")
    profile_path = decoded_secret_file("IOS_PROVISIONING_PROFILE_BASE64", "ios/App/build/profiles/current_almanac.mobileprovision")

    create_keychain(
      name: "current-almanac-ci",
      password: require_env!("IOS_KEYCHAIN_PASSWORD"),
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )
    import_certificate(
      certificate_path: certificate_path,
      certificate_password: require_env!("IOS_DISTRIBUTION_CERTIFICATE_PASSWORD"),
      keychain_name: "current-almanac-ci",
      keychain_password: require_env!("IOS_KEYCHAIN_PASSWORD")
    )
    install_provisioning_profile(path: profile_path)

    update_code_signing_settings(
      path: "ios/App/App.xcodeproj",
      use_automatic_signing: false,
      team_id: require_env!("APPLE_TEAM_ID"),
      profile_name: ENV["IOS_PROVISIONING_PROFILE_NAME"],
      code_sign_identity: "Apple Distribution"
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "ios/App/build",
      output_name: "CurrentAlmanac.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "ios/App/build/CurrentAlmanac.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end

platform :android do
  desc "Build and upload Current Almanac to Google Play internal testing"
  lane :internal do
    package_name = ENV.fetch("ANDROID_PACKAGE_NAME", "com.current.almanac")
    keystore_path = decoded_secret_file("ANDROID_KEYSTORE_BASE64", "android/app/release.keystore")
    json_key_path = decoded_secret_file("GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64", "android/app/google-play-service-account.json")

    gradle(
      project_dir: "android",
      task: "clean bundleRelease",
      properties: {
        "android.injected.signing.store.file" => File.expand_path(keystore_path),
        "android.injected.signing.store.password" => require_env!("ANDROID_KEYSTORE_PASSWORD"),
        "android.injected.signing.key.alias" => require_env!("ANDROID_KEY_ALIAS"),
        "android.injected.signing.key.password" => require_env!("ANDROID_KEY_PASSWORD")
      }
    )

    upload_to_play_store(
      package_name: package_name,
      track: ENV.fetch("GOOGLE_PLAY_TRACK", "internal"),
      json_key: json_key_path,
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
